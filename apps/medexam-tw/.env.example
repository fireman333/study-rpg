# Supabase cloud sync (M4 milestone)
# Real values live in .env.local (gitignored). For GitHub Actions deploy,
# wire these via Secrets → VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Toggle cloud sync engine without rebuilding (default true).
# Set false to fully disable sync (sign-in UI stays but engine no-ops).
VITE_CLOUD_SYNC_ENABLED=true

# Debounced auto-push window after IndexedDB writes, milliseconds.
# 3000–5000 is the design sweet spot. Lower = more pushes, higher = larger
# window where a tab crash loses progress.
VITE_SYNC_DEBOUNCE_MS=3000

# Cloud-sync backend selector (R2 migration, Phase 1+).
#   supabase = legacy row-level Postgres (M4 default)
#   dual     = write to both Supabase AND R2 (Phase 1–3)
#   r2       = R2 blob only (Phase 4+)
VITE_CLOUD_SYNC_BACKEND=supabase

# Where reads come from. Only honored when BACKEND=dual.
#   supabase = Phase 1–2 (reads still on legacy)
#   r2       = Phase 3 (reads cut over to R2)
# Invalid combinations (BACKEND=supabase + READ_BACKEND=r2) fail fast.
VITE_CLOUD_SYNC_READ_BACKEND=supabase

# Cloudflare Worker base URL (auth-bridging presigner). Default points at
# the prod Worker; override locally via .env.local if running `wrangler dev`.
VITE_SYNC_WORKER_URL=https://study-rpg-sync-worker.tony85314.workers.dev
