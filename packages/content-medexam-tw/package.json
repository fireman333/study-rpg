{
  "name": "@study-rpg/content-medexam-tw",
  "version": "0.0.1",
  "description": "Content pack: Taiwan Stage-1 medical board exam past questions (一階醫師國考 106-1 to 114-2, 10 subjects, ~3505 questions). Built from 陽明國考考古題小組 .md corpus.",
  "license": "CC-BY-NC-4.0",
  "type": "module",
  "main": "./src/index.ts",
