    "./questions.json": "./dist/questions.json"
  },
  "scripts": {
    "build": "tsx scripts/build.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@study-rpg/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "yaml": "^2.5.0"
  }
}
