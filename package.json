{
  "name": "study-rpg",
  "version": "0.0.1",
  "private": true,
  "description": "Open-source gamified study RPG engine. Default content pack: Taiwan Stage-1 medical board exam (一階醫師國考).",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @study-rpg/medexam-tw dev",
    "dev:m2": "pnpm --filter @study-rpg/medexam2-hospital-tw dev",
    "build": "pnpm -r build",
    "build:m2": "pnpm -r --filter @study-rpg/core --filter @study-rpg/medexam2-hospital-tw build",
    "build:content": "pnpm --filter @study-rpg/content-medexam-tw build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "gen-status": "node scripts/gen-status.mjs"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
